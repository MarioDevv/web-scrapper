# App
APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:GENERATE_YOUR_KEY
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Database (SQLite)
DB_CONNECTION=sqlite
DB_DATABASE=

# Cache & Session
CACHE_STORE=file
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

# Queue
QUEUE_CONNECTION=database

# Mail (para desarrollo)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# NativePHP PHP binary path
NATIVEPHP_PHP_BINARY_PATH=

# Optional: updater config (solo si usas NativePHP auto-updater)
NATIVEPHP_UPDATER_ENABLED=false