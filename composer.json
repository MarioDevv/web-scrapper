{
    "name": "seo-spider/seo-spider",
    "description": "Open source SEO site audit crawler",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "ext-pdo": "*",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.10.1",
        "livewire/livewire": "^4.2",
        "nativephp/electron": "^1.3",
        "symfony/css-selector": "^7.2|^8.0",
        "symfony/dom-crawler": "^7.2|^8.0",
        "symfony/http-client": "^7.2|^8.0",
        "symfony/uid": "^7.2|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.24"
    },
    "autoload": {
        "psr-4": {
            "SeoSpider\\": "src/",
            "App\\": "src/Audit/Infrastructure/Delivery/NativePHP/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SeoSpider\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "native:dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -k -c \"#93c5fd,#c4b5fd\" \"php artisan native:serve --no-interaction\" \"npm run dev\" --names=app,vite"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable"
}
