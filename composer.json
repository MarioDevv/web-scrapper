{
    "name": "seo-spider/seo-spider",
    "description": "Open source SEO site audit crawler",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "symfony/uid": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "SeoSpider\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SeoSpider\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
